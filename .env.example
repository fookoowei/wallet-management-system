# --- Postgres credentials ---
# Consumed by docker-compose.yml via ${...} substitution (creates the DB user/db).
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="wallet_db"

# --- Database connection string ---
# Consumed by the app / Prisma. Must stay consistent with the POSTGRES_* values above:
#   postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/<POSTGRES_DB>
DATABASE_URL="postgresql://user:password@localhost:5432/wallet_db"

# --- Auth secrets (used later, in the authentication milestone) ---
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
